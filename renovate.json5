{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  extends: [ "github>SonarSource/renovate-config:quality-jvm-squad" ],
  ignorePaths: [
    "docs/**",
    "its/sources/**",
    "its/plugin/projects/**",
    "java-checks-test-sources/**",
    "java-surefire/src/test/resources/**",
  ],
  packageRules: [
    {
      matchPackageNames: [
        "org.sonarsource.sslr*"
      ],
      groupName: "SSLR",
      groupSlug: "sslr",
    }
  ],
}
