{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>SonarSource/core-languages-tooling-public:quality-jvm-squad"
  ],
  "ignorePaths": [
    "docs/**",
    "its/sources/**",
    "its/plugin/projects/**",
    "java-checks-test-sources/**",
    "java-surefire/src/test/resources/**"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "org.sonarsource.sslr*"
      ],
      "groupName": "SSLR",
      "groupSlug": "sslr"
    },
    {
      "matchPackageNames": [
        "org.slf4j:**",
        "org.slf4j"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ]
}
